# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nova?retryWrites=true&w=majority

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
GOOGLE_CLIENT_ID=

# ── LLM Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ── Payments ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Notifications ─────────────────────────────────────────────────────────────
MSG91_API_KEY=
MSG91_TEMPLATE_ID=
SENDGRID_API_KEY=

# ── Apollo ────────────────────────────────────────────────────────────────────
APOLLO_KEY=
APOLLO_GRAPH_REF=
